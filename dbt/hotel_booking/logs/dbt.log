    SUM(estimated_revenue) AS estimated_revenue,
    SUM(realized_revenue) AS realized_revenue,
    AVG(adr) AS average_adr
FROM `hotel_booking`.`fact_bookings`
WHERE arrival_date IS NOT NULL
GROUP BY arrival_date
  
