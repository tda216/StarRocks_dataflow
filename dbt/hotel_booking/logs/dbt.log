  create table `hotel_booking`.`mart_cancellation_analysis__dbt_tmp`
      DUPLICATE KEY (hotel,market_segment,distribution_channel)
    DISTRIBUTED BY HASH (hotel)BUCKETS 8
    PROPERTIES (
      "replication_num" = "1"
    )
