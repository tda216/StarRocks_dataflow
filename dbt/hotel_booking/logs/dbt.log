    )
  as 

WITH ranked AS (
    SELECT
        *,
        ROW_NUMBER() OVER (
            PARTITION BY booking_key, batch_id, record_hash
            ORDER BY row_ingestion_id, ingested_at
        ) AS duplicate_rank
